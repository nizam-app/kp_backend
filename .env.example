# Required
MONGODB_URL=mongodb://127.0.0.1:27017/truckfix
JWT_SECRET=your-long-random-secret

# Render: set these in the Web Service dashboard (do not commit .env).
# PORT is injected automatically by Render.
# NODE_ENV=production

# Cloudinary (profile / logo uploads — POST /api/v1/media/profile-image)
# Easiest: paste the full URL from the Cloudinary dashboard
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Or set these three instead of CLOUDINARY_URL:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional — public app URL (no trailing slash) for company invite signup links in API responses
# Example: https://app.truckfix.example or http://localhost:5173
APP_PUBLIC_URL=

# Optional — Firebase Cloud Messaging (push). Install deps; download service account JSON from Firebase Console.
# Use either a file path (relative to server cwd or absolute) OR paste JSON as a single line (escape quotes in .env).
# FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Resend — transactional email (password reset, invites)
# https://resend.com/api-keys — testing: onboarding@resend.dev (only to your Resend account email)
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=TruckFix <onboarding@resend.dev>
# Optional — defaults to APP_PUBLIC_URL/reset-password?token=...
# PASSWORD_RESET_URL=http://localhost:5173/reset-password